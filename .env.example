SECRET_KEY=change-me
DEBUG=True

DB_NAME=tournament_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Варіант 1. SMTP. Працює локально та на платних інстансах Render.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_mail@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=your_mail@gmail.com
EMAIL_SENDER_NAME=Tournament Platform

# Варіант 2. Brevo API. Рекомендовано для безкоштовного Render.
# EMAIL_DELIVERY_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=verified-sender@example.com
# EMAIL_SENDER_NAME=Tournament Platform

ALLOWED_HOSTS=127.0.0.1,localhost,serverdenis.pp.ua
CSRF_TRUSTED_ORIGINS=https://serverdenis.pp.ua
